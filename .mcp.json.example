{
  "mcpServers": {
    "podio": {
      "command": "node",
      "args": ["/path/to/podio-mcp/dist/index.js"],
      "env": {
        "PODIO_CLIENT_ID": "YOUR_CLIENT_ID",
        "PODIO_CLIENT_SECRET": "YOUR_CLIENT_SECRET",
        "PODIO_USERNAME": "YOUR_PODIO_EMAIL",
        "PODIO_PASSWORD": "YOUR_PODIO_PASSWORD"
      }
    }
  }
}
